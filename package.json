{
  "name": "css-sentry",
  "description": "Browser extension for detecting and reducing CSS-based data exfiltration risk.",
  "private": true,
  "version": "1.0.77",
  "type": "module",
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt -b firefox",
    "build": "wxt build",
    "build:firefox": "wxt build -b firefox",
    "zip": "wxt zip",
    "zip:firefox": "wxt zip -b firefox",
    "compile": "tsc --noEmit",
    "test": "vitest run --no-color",
    "test:ai": "vitest run --no-color --config vitest.ai.config.ts",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "setup:e2e:browser": "pnpm exec playwright install chromium firefox",
    "setup:e2e:arch": "node scripts/playwright-arch-help.mjs",
    "test:e2e:with-install": "pnpm build && pnpm build:firefox && pnpm setup:e2e:browser && pnpm test:e2e",
    "verify:full": "pnpm build && pnpm build:firefox && pnpm zip && pnpm zip:firefox && pnpm verify:manifests && pnpm verify:release-artifacts && pnpm verify:ai-report && pnpm verify:source-css && pnpm compile && pnpm test && pnpm setup:e2e:browser && pnpm test:e2e",
    "audit:false-positives": "node scripts/false-positive-sweep.mjs",
    "audit:false-positives:all": "node scripts/false-positive-sweep.mjs --limit 250 --save-reports all",
    "verify:full:diagnose": "pnpm build; pnpm build:firefox; pnpm zip; pnpm zip:firefox; pnpm verify:manifests; pnpm verify:release-artifacts; pnpm verify:ai-report; pnpm verify:source-css; pnpm compile; pnpm test; pnpm test:ai; pnpm setup:e2e:browser; pnpm test:e2e",
    "verify:manifests": "node scripts/verify-generated-manifests.mjs",
    "verify:release-artifacts": "node scripts/verify-release-artifacts.mjs",
    "verify:ai-report": "node scripts/verify-ai-report-config.mjs",
    "verify:source-css": "node scripts/verify-source-css-format.mjs",
    "website:dev": "pnpm --filter css-sentry-website dev",
    "website:build": "pnpm --filter css-sentry-website build",
    "website:preview": "pnpm --filter css-sentry-website preview",
    "website:astro": "pnpm --filter css-sentry-website astro",
    "verify:website-source": "node scripts/verify-website-source.mjs"
  },
  "dependencies": {
    "css-tree": "3.2.1",
    "react": "19.2.6",
    "react-dom": "19.2.6"
  },
  "devDependencies": {
    "@playwright/test": "1.60.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/css-tree": "^2.3.11",
    "@types/node": "25.7.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "6.0.1",
    "@wxt-dev/auto-icons": "^1.1.1",
    "@wxt-dev/module-react": "1.2.2",
    "jsdom": "29.1.1",
    "node-addon-api": "^8.7.0",
    "node-gyp": "^12.3.0",
    "typescript": "6.0.3",
    "vitest": "4.1.6",
    "wxt": "0.20.26"
  }
}
