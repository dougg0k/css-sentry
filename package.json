{
	"name": "css-sentry",
	"description": "Browser extension for detecting and reducing CSS-based data exfiltration risk.",
	"private": true,
	"version": "1.0.34",
	"type": "module",
	"scripts": {
		"dev": "wxt",
		"dev:firefox": "wxt -b firefox",
		"build": "wxt build",
		"build:firefox": "wxt build -b firefox",
		"zip": "wxt zip",
		"zip:firefox": "wxt zip -b firefox",
		"compile": "tsc --noEmit",
		"test": "vitest run --no-color",
		"test:ai": "vitest run --no-color --config vitest.ai.config.ts",
		"test:watch": "vitest",
		"test:e2e": "playwright test",
		"setup:e2e:browser": "pnpm exec playwright install chromium",
		"setup:e2e:arch": "node scripts/playwright-arch-help.mjs",
		"test:e2e:with-install": "pnpm build && pnpm setup:e2e:browser && playwright test",
		"verify:full": "pnpm build; pnpm build:firefox; pnpm compile; pnpm test; pnpm test:e2e",
		"audit:false-positives": "node scripts/false-positive-sweep.mjs",
		"audit:false-positives:all": "node scripts/false-positive-sweep.mjs --limit 250 --save-reports all"
	},
	"dependencies": {
		"css-tree": "3.2.1",
		"react": "19.2.6",
		"react-dom": "19.2.6"
	},
	"devDependencies": {
		"@playwright/test": "1.60.0",
		"@testing-library/dom": "^10.4.1",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/react": "16.3.2",
		"@types/css-tree": "^2.3.11",
		"@types/node": "25.7.0",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "latest",
		"@wxt-dev/auto-icons": "^1.1.1",
		"@wxt-dev/module-react": "1.2.2",
		"jsdom": "29.1.1",
		"node-addon-api": "^8.7.0",
		"node-gyp": "^12.3.0",
		"typescript": "6.0.3",
		"vitest": "4.1.6",
		"wxt": "0.20.26"
	}
}
