{
  "description": "A scroll/layout-state probe using content-visibility, overflow sizing, and a remote unicode-range font is reported only when the experimental fingerprinting guard is enabled.",
  "enableCssFingerprintingGuard": true,
  "minActionableFindings": 1,
  "severityAtLeast": "low",
  "requiredReasons": [
    "privacy.css_fingerprinting.conditional_resource",
    "privacy.css_fingerprinting.layout_overflow_signal",
    "privacy.css_fingerprinting.scroll_signal",
    "sink.font_remote",
    "sink.font_unicode_range_remote",
    "url.cross_origin"
  ],
  "requiredDestinationOrigins": ["https://attacker.example"],
  "mustNotBeBlockCandidate": true
}
