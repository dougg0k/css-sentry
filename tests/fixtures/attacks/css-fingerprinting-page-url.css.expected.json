{
  "description": "When the experimental CSS fingerprinting guard is enabled, an @page remote resource is reported as a print-related CSS fingerprinting indicator.",
  "enableCssFingerprintingGuard": true,
  "minActionableFindings": 1,
  "severityAtLeast": "low",
  "requiredReasons": [
    "privacy.css_fingerprinting.conditional_resource",
    "privacy.css_fingerprinting.page_rule_signal",
    "privacy.css_fingerprinting.print_signal",
    "sink.remote_url",
    "url.cross_origin"
  ],
  "requiredDestinationOrigins": [
    "https://observer.example.test"
  ],
  "mustNotBeBlockCandidate": true
}
