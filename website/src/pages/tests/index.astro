---
export const prerender = true;

import "../../styles/global.css";
import { MODE_DEFINITIONS, TEST_CASES, TEST_CASE_CATEGORIES } from "../../data/testCases";
import { DEFAULT_MODE, DEFAULT_TEST_CASE_IDS, TURNSTILE_TEST_LAB_ACTION, endpointUrl } from "../../lib/testProtocol";

const defaultCaseSet = new Set<string>(DEFAULT_TEST_CASE_IDS);
const turnstileSiteKey = import.meta.env.PUBLIC_TURNSTILE_SITE_KEY ?? "";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="CSS Sentry Test Lab runner for controlled CSS data-probe behavior checks." />
    <meta name="css-sentry-test-lab" content="v1" />
    <title>Run checks · CSS Sentry Test Lab</title>
    {turnstileSiteKey && <link rel="preconnect" href="https://challenges.cloudflare.com" />}
    {turnstileSiteKey && <script src="https://challenges.cloudflare.com/turnstile/v0/api.js?render=explicit" defer></script>}
    <script is:inline>
      (() => {
        const searchParams = new URLSearchParams(window.location.search);
        const sessionId = searchParams.get("session");
        if (!/^[a-f0-9-]{36}$/i.test(sessionId ?? "")) return;
        const cases = searchParams.get("cases") ?? "";
        const link = document.createElement("link");
        link.id = "initial-test-style";
        link.rel = "stylesheet";
        link.href = `/api/controlled-css/${encodeURIComponent(sessionId)}.css${cases ? `?cases=${encodeURIComponent(cases)}` : ""}`;
        document.head.appendChild(link);
      })();
    </script>
  </head>
  <body>
    <main class="site-shell test-runner-page">
      <nav class="top-nav" aria-label="Test lab navigation">
        <a href="/">Overview</a>
        <a href="/history/">History</a>
        <a href="/troubleshooting/">Troubleshooting</a>
      </nav>

      <section class="hero test-hero runner-hero">
        <div class="hero-content">
          <p class="eyebrow">CSS Sentry Test Lab</p>
          <h1>Run controlled checks in one place.</h1>
          <p class="lede">Select one check, one category, or all available checks. The page adds the selected controlled stylesheet before the browser finishes parsing the page so CSS Sentry can scan normal page content while only the test endpoints remain dynamic.</p>
        </div>
        <div class="hero-actions compact-actions">
          <div class="runner-status-card">
            <span class="state-label">Detected extension mode</span>
            <strong id="detected-mode">waiting for CSS Sentry signal</strong>
          </div>
          <div class="runner-status-card">
            <span class="state-label">Active session</span>
            <strong id="session-state">not started</strong>
          </div>
          <div class="runner-status-card turnstile-status-card">
            <span class="state-label">Turnstile verification</span>
            <strong id="turnstile-state">{turnstileSiteKey ? "loading verification" : "not configured"}</strong>
            {turnstileSiteKey && <div id="turnstile-widget" class="turnstile-widget" data-sitekey={turnstileSiteKey} data-action={TURNSTILE_TEST_LAB_ACTION}></div>}
          </div>
          <button id="start-selected" class="button" type="button">Start selected checks</button>
          <button id="run-all" class="button secondary" type="button">Run all checks</button>
          <button id="reset-run" class="button secondary" type="button">Reset</button>
        </div>
      </section>

      <section class="section panel diagnostic-panel" aria-label="Current diagnostic state">
        <div class="section-heading compact">
          <div>
            <p class="eyebrow">Current result</p>
            <h2>Endpoint, scan signal, report save, and manual confirmation</h2>
          </div>
          <p>The endpoint result, CSS Sentry scan signal, background report-save acknowledgement, and popup/report confirmation are separate evidence sources.</p>
        </div>
        <div class="diagnostic-grid result-grid">
          <div>
            <span class="state-label">Extension scan signal</span>
            <strong id="scan-signal-state">waiting for CSS Sentry signal</strong>
          </div>
          <div>
            <span class="state-label">Report save signal</span>
            <strong id="report-signal-state">waiting for report acknowledgement</strong>
          </div>
          <div>
            <span class="state-label">Selected checks</span>
            <strong id="selected-count">{DEFAULT_TEST_CASE_IDS.length}</strong>
          </div>
          <div>
            <span class="state-label">Endpoint hits</span>
            <strong id="endpoint-hit-count">not started</strong>
          </div>
        </div>
        <div id="global-interpretation" class="interpretation-card review">
          <strong>Interpretation pending</strong>
          <p>Start selected checks to add a controlled stylesheet to this static page and poll the dynamic endpoint results.</p>
        </div>
      </section>

      <section class="section panel">
        <div class="section-heading compact">
          <div>
            <p class="eyebrow">Selection</p>
            <h2>Choose checks by behavior</h2>
          </div>
          <p>Start with the known detector check. Optional and manual-explanation checks are useful after the baseline path works.</p>
        </div>
        <div class="category-actions" aria-label="Run category shortcuts">
          {TEST_CASE_CATEGORIES.map((category) => <button class="button secondary small category-button" type="button" data-category={category}>Select {category}</button>)}
        </div>
        <div class="runner-check-list">
          {TEST_CASES.map((testCase) => (
            <label class={`runner-check ${defaultCaseSet.has(testCase.id) ? "selected" : ""}`} data-case-label={testCase.id}>
              <input type="checkbox" name="case" value={testCase.id} checked={defaultCaseSet.has(testCase.id)} data-category={testCase.category} />
              <span>
                <strong>{testCase.title}</strong>
                <small>{testCase.category} · {testCase.status} · {testCase.riskClass}</small>
              </span>
            </label>
          ))}
        </div>
        <details class="manual-mode-override">
          <summary>Manual mode override</summary>
          <p>Use this only if the extension signal is unavailable. When CSS Sentry reports its mode, the detected value is used automatically.</p>
          <div class="mode-options compact-mode-options">
            {MODE_DEFINITIONS.map((mode) => (
              <label class="mode-option">
                <input type="radio" name="mode" value={mode.id} checked={mode.id === DEFAULT_MODE} />
                <span>{mode.shortLabel}</span>
              </label>
            ))}
          </div>
        </details>
      </section>

      <section class="section panel">
        <div class="section-heading compact">
          <div>
            <p class="eyebrow">Fake fixture</p>
            <h2>Controlled page data</h2>
          </div>
          <p>All values are harmless sentinel strings. The visible probe surface is where selected CSS applies controlled URL requests.</p>
        </div>
        <div id="css-sentry-fixtures" class="fixture-preview css-sentry-font-measure-container" data-lab-token="CSS-SENTRY-SENTINEL-ALPHA-12345" aria-label="Fake CSS Sentry test fixture">
          <input type="hidden" value="CSS-SENTRY-SENTINEL-smoke-secret" />
          <input type="hidden" name="session_token" value="CSS-SENTRY-SENTINEL-ALPHA-12345" />
          <input type="hidden" name="recovery_code" value="CSS-SENTRY-SENTINEL-RECOVERY-67890" />
          <div id="css-sentry-visible-probe" class="probe-surface">
            <strong>Visible probe surface</strong>
            <span>Selected CSS applies controlled requests here when fake selectors or represented mechanisms match.</span>
          </div>
        </div>
      </section>

      <section class="section panel">
        <div class="section-heading compact">
          <div>
            <p class="eyebrow">Live result rows</p>
            <h2>Selected checks</h2>
          </div>
          <p>Expand a row to inspect scenario, fake data, CSS, expected reason terms, fixture references, limitations, and report confirmation.</p>
        </div>
        <div class="test-result-list">
          {TEST_CASES.map((testCase) => (
            <article class="test-result-card" data-case-id={testCase.id} hidden={!defaultCaseSet.has(testCase.id)}>
              <header class="test-result-header">
                <div>
                  <p class="eyebrow">{testCase.category}</p>
                  <h3>{testCase.title}</h3>
                  <p>{testCase.question}</p>
                </div>
                <div class="result-pills" aria-label={`${testCase.title} result states`}>
                  <span>Endpoint: <strong data-endpoint-state={testCase.id}>not started</strong></span>
                  <span>Manual: <strong data-manual-state={testCase.id}>not checked</strong></span>
                </div>
              </header>
              <details>
                <summary>Scenario, CSS, and report expectations</summary>
                <div class="test-detail-grid">
                  <section>
                    <h4>Scenario</h4>
                    <p>{testCase.riskScenario}</p>
                    <p><strong>Endpoint meaning:</strong> {testCase.endpointRequestMeaning}</p>
                    <code class="endpoint-code" data-endpoint-code={testCase.id}>{endpointUrl("http://localhost", testCase.id, "SESSION_ID")}</code>
                  </section>
                  <section>
                    <h4>Expected report terms</h4>
                    <p>{testCase.expectedReportText}</p>
                    <ul class="term-list">{testCase.expectedCssSentryFindings.map((term) => <li><code>{term}</code></li>)}</ul>
                  </section>
                  <section>
                    <h4>Fixture and source references</h4>
                    <ul class="check-list">{testCase.fixtureReferences.map((fixture) => <li>{fixture}</li>)}</ul>
                  </section>
                  <section>
                    <h4>Manual CSS Sentry result</h4>
                    <fieldset class="extension-check" data-manual-group={testCase.id}>
                      <label><input type="radio" name={`extension-result-${testCase.id}`} value="not-checked" checked /> Not checked yet</label>
                      <label><input type="radio" name={`extension-result-${testCase.id}`} value="reported" /> Reported this check</label>
                      <label><input type="radio" name={`extension-result-${testCase.id}`} value="blocked" /> Reported and blocked</label>
                      <label><input type="radio" name={`extension-result-${testCase.id}`} value="sanitized" /> Reported and sanitized</label>
                      <label><input type="radio" name={`extension-result-${testCase.id}`} value="no-finding" /> No finding shown</label>
                      <label><input type="radio" name={`extension-result-${testCase.id}`} value="unsure" /> I am not sure</label>
                    </fieldset>
                  </section>
                </div>
                <h4>CSS rendered for this check</h4>
                <pre class="code-block"><code data-css-code={testCase.id}>{testCase.userVisibleCss}</code></pre>
                <h4>Limitations</h4>
                <ul class="check-list">{testCase.limitations.map((limitation) => <li>{limitation}</li>)}</ul>
              </details>
            </article>
          ))}
        </div>
      </section>

      <script>
        import { TEST_CASES } from "../../data/testCases";
        import { TURNSTILE_TEST_LAB_ACTION, endpointUrl, isValidTestSessionId, parseRequestedCaseList, parseRequestedMode, serializeCaseList, testLabDiagnosticOrigin, visibleCssForTestCase } from "../../lib/testProtocol";

        const historyKey = "css-sentry-test-lab-history";
        const scanDiagnosticEventName = "css-sentry:test-lab-scan";
        const reportDiagnosticEventName = "css-sentry:test-lab-report";
        const scanDiagnosticAttribute = "data-css-sentry-test-lab-scan";
        const reportDiagnosticAttribute = "data-css-sentry-test-lab-report";
        const diagnosticMessageSource = "css-sentry-test-lab";
        const currentUrl = new URL(window.location.href);
        const turnstileWidgetElement = document.querySelector("#turnstile-widget");
        const turnstileState = {
          enabled: Boolean(turnstileWidgetElement?.getAttribute("data-sitekey")),
          siteKey: turnstileWidgetElement?.getAttribute("data-sitekey") ?? "",
          widgetId: null,
          token: null,
          rendered: false,
          loadAttempts: 0,
        };
        const requestedSessionId = currentUrl.searchParams.get("session");
        const activeSessionId = isValidTestSessionId(requestedSessionId) ? requestedSessionId : null;
        const selectedCaseIds = parseRequestedCaseList(currentUrl.searchParams.get("cases"));
        const selectedCaseSet = new Set(selectedCaseIds);
        const diagnosticOrigin = testLabDiagnosticOrigin(currentUrl.hostname);
        const runConfig = {
          sessionId: activeSessionId,
          cases: selectedCaseIds,
          mode: parseRequestedMode(currentUrl.searchParams.get("mode")),
          resultPath: activeSessionId ? resultPathForSession(activeSessionId, selectedCaseIds) : null,
          diagnosticOrigin,
        };
        const state = {
          mode: runConfig.mode,
          scan: "waiting",
          report: "waiting",
          endpointByCase: Object.fromEntries(runConfig.cases.map((caseId) => [caseId, runConfig.sessionId ? "pending" : "not-run"])),
          manualByCase: Object.fromEntries(runConfig.cases.map((caseId) => [caseId, "not-checked"])),
          lastScanDiagnosticRaw: "",
          lastReportDiagnosticRaw: "",
        };
        let activeRunToken = 0;

        document.documentElement.addEventListener(scanDiagnosticEventName, (event) => {
          applyScanDiagnosticFromRaw(event.detail);
        });

        document.documentElement.addEventListener(reportDiagnosticEventName, (event) => {
          applyReportDiagnosticFromRaw(event.detail);
        });

        window.addEventListener("message", (event) => {
          if (event.source !== window || event.origin !== window.location.origin) return;
          const message = event.data;
          if (!message || message.source !== diagnosticMessageSource || typeof message.detail !== "string") return;
          if (message.eventName === scanDiagnosticEventName) applyScanDiagnosticFromRaw(message.detail);
          if (message.eventName === reportDiagnosticEventName) applyReportDiagnosticFromRaw(message.detail);
        });

        observeStoredDiagnostics();
        initializeTurnstile();

        document.querySelectorAll("[data-manual-group] input").forEach((input) => {
          input.addEventListener("change", () => {
            const group = input.closest("[data-manual-group]");
            const caseId = group?.getAttribute("data-manual-group");
            if (!caseId) return;
            state.manualByCase[caseId] = input.value;
            const target = document.querySelector(`[data-manual-state="${cssEscape(caseId)}"]`);
            if (target) target.textContent = manualLabel(input.value);
            updateGlobalInterpretation();
            storeHistory("manual-confirmation", { caseId, value: input.value });
          });
        });

        document.querySelectorAll("input[name='mode']").forEach((input) => {
          input.addEventListener("change", () => {
            if (!input.checked) return;
            state.mode = input.value;
            setText("#detected-mode", `manual override: ${state.mode}`);
            updateGlobalInterpretation();
          });
        });

        document.querySelectorAll("input[name='case']").forEach((input) => {
          input.addEventListener("change", syncSelectedFromInputs);
        });

        document.querySelectorAll(".category-button").forEach((button) => {
          button.addEventListener("click", () => {
            const category = button.getAttribute("data-category");
            document.querySelectorAll("input[name='case']").forEach((input) => { input.checked = input.getAttribute("data-category") === category; });
            syncSelectedFromInputs();
          });
        });

        document.querySelector("#run-all")?.addEventListener("click", () => {
          document.querySelectorAll("input[name='case']").forEach((input) => { input.checked = true; });
          startSelectedChecks();
        });

        document.querySelector("#start-selected")?.addEventListener("click", startSelectedChecks);
        document.querySelector("#reset-run")?.addEventListener("click", async () => {
          await fetch("/api/reset.json", { method: "POST" }).catch(() => null);
          window.location.assign("/tests/");
        });

        initializeStaticRunner();

        if (runConfig.sessionId) startRuntimeObservation();

        function initializeStaticRunner() {
          setText("#session-state", runConfig.sessionId ?? "not started");
          setText("#detected-mode", runConfig.diagnosticOrigin === "unsupported" ? "manual confirmation required on this origin" : "waiting for CSS Sentry signal");
          setText("#scan-signal-state", runConfig.diagnosticOrigin === "unsupported" ? "diagnostic signal unavailable on this origin" : "waiting for CSS Sentry signal");
          setText("#report-signal-state", runConfig.diagnosticOrigin === "unsupported" ? "manual report confirmation required" : "waiting for report acknowledgement");
          applySelectedCases(selectedCaseSet);
          const modeInput = document.querySelector(`input[name='mode'][value='${cssEscape(runConfig.mode)}']`);
          if (modeInput) modeInput.checked = true;
          applyStoredDiagnostics();
          updateEndpointCount();
          updateGlobalInterpretation();
        }

        function syncSelectedFromInputs() {
          const selected = new Set([...document.querySelectorAll("input[name='case']")].filter((input) => input.checked).map((input) => input.value));
          applySelectedCases(selected);
        }

        function applySelectedCases(selected) {
          for (const input of document.querySelectorAll("input[name='case']")) {
            const selectedCase = selected.has(input.value);
            input.checked = selectedCase;
            input.closest("[data-case-label]")?.classList.toggle("selected", selectedCase);
          }
          for (const card of document.querySelectorAll("[data-case-id]")) {
            const caseId = card.getAttribute("data-case-id");
            card.hidden = !caseId || !selected.has(caseId);
          }
          for (const testCase of TEST_CASES) {
            const endpoint = endpointUrl(window.location.origin, testCase.id, runConfig.sessionId ?? "SESSION_ID");
            const endpointTarget = document.querySelector(`[data-endpoint-code='${cssEscape(testCase.id)}']`);
            if (endpointTarget) endpointTarget.textContent = endpoint;
            const cssTarget = document.querySelector(`[data-css-code='${cssEscape(testCase.id)}']`);
            if (cssTarget) cssTarget.textContent = runConfig.sessionId ? visibleCssForTestCase(testCase.id, runConfig.sessionId, window.location.origin) : testCase.userVisibleCss;
            const endpointState = document.querySelector(`[data-endpoint-state='${cssEscape(testCase.id)}']`);
            if (endpointState) endpointState.textContent = selected.has(testCase.id) ? (state.endpointByCase[testCase.id] === "not-run" ? "not started" : state.endpointByCase[testCase.id] ?? "not started") : "not selected";
          }
          setText("#selected-count", String(selected.size));
        }

        function initializeTurnstile() {
          if (!turnstileState.enabled) {
            setText("#turnstile-state", "not configured");
            return;
          }
          renderTurnstileWhenReady();
        }

        function renderTurnstileWhenReady() {
          if (!turnstileState.enabled || turnstileState.rendered) return;
          const turnstileApi = window.turnstile;
          if (turnstileApi?.render) {
            renderTurnstileWidget(turnstileApi);
            return;
          }
          turnstileState.loadAttempts += 1;
          if (turnstileState.loadAttempts > 40) {
            setText("#turnstile-state", "verification script unavailable");
            return;
          }
          window.setTimeout(renderTurnstileWhenReady, 150);
        }

        function renderTurnstileWidget(turnstileApi) {
          if (!turnstileWidgetElement || !turnstileState.siteKey || turnstileState.rendered) return;
          turnstileState.widgetId = turnstileApi.render(turnstileWidgetElement, {
            sitekey: turnstileState.siteKey,
            action: TURNSTILE_TEST_LAB_ACTION,
            theme: "auto",
            callback: (token) => {
              turnstileState.token = token;
              setText("#turnstile-state", "verified for next run");
            },
            "expired-callback": () => {
              turnstileState.token = null;
              setText("#turnstile-state", "verification expired");
            },
            "error-callback": () => {
              turnstileState.token = null;
              setText("#turnstile-state", "verification failed");
            },
          });
          turnstileState.rendered = true;
          setText("#turnstile-state", "verification required");
        }

        function turnstileTokenForSession() {
          if (!turnstileState.enabled) return null;
          const liveToken = window.turnstile?.getResponse && turnstileState.widgetId !== null ? window.turnstile.getResponse(turnstileState.widgetId) : null;
          return typeof liveToken === "string" && liveToken ? liveToken : turnstileState.token;
        }

        function resetTurnstile() {
          if (!turnstileState.enabled || turnstileState.widgetId === null || !window.turnstile?.reset) return;
          turnstileState.token = null;
          window.turnstile.reset(turnstileState.widgetId);
          setText("#turnstile-state", "verification required");
        }

        function sessionFailureLabel(body) {
          const reason = body?.turnstile?.reason;
          if (reason === "missing-token") return "Turnstile verification required";
          if (typeof reason === "string" && reason.startsWith("siteverify-")) return "Turnstile verification failed";
          return "session creation failed";
        }

        async function startSelectedChecks() {
          const selectedCases = [...document.querySelectorAll("input[name='case']")].filter((input) => input.checked).map((input) => input.value);
          if (selectedCases.length === 0) return;
          const turnstileToken = turnstileTokenForSession();
          if (turnstileState.enabled && !turnstileToken) {
            setText("#session-state", "complete Turnstile before starting checks");
            setText("#turnstile-state", "verification required");
            return;
          }
          const response = await fetch("/api/session.json", { method: "POST", headers: { "content-type": "application/json" }, body: JSON.stringify(turnstileToken ? { turnstileToken } : {}) });
          const body = await response.json().catch(() => null);
          if (!response.ok || body?.ok !== true || !isValidTestSessionId(body.sessionId)) {
            setText("#session-state", sessionFailureLabel(body));
            resetTurnstile();
            return;
          }
          resetTurnstile();
          beginSelectedRun(body.sessionId, selectedCases);
        }

        function beginSelectedRun(sessionId, selectedCases) {
          const url = new URL(window.location.href);
          url.searchParams.set("session", sessionId);
          url.searchParams.set("cases", selectedCases.join(","));
          url.searchParams.set("mode", state.mode);
          window.history.pushState({}, "", url);

          activeRunToken += 1;
          runConfig.sessionId = sessionId;
          runConfig.cases = selectedCases;
          runConfig.mode = state.mode;
          runConfig.resultPath = resultPathForSession(sessionId, selectedCases);
          state.scan = "waiting";
          state.report = "waiting";
          state.endpointByCase = Object.fromEntries(selectedCases.map((caseId) => [caseId, "pending"]));
          state.manualByCase = Object.fromEntries(selectedCases.map((caseId) => [caseId, "not-checked"]));
          state.lastScanDiagnosticRaw = "";
          state.lastReportDiagnosticRaw = "";

          setText("#session-state", sessionId);
          setText("#detected-mode", runConfig.diagnosticOrigin === "unsupported" ? "manual confirmation required on this origin" : "waiting for CSS Sentry signal");
          setText("#scan-signal-state", runConfig.diagnosticOrigin === "unsupported" ? "diagnostic signal unavailable on this origin" : "waiting for CSS Sentry signal");
          setText("#report-signal-state", runConfig.diagnosticOrigin === "unsupported" ? "manual report confirmation required" : "waiting for report acknowledgement");
          applySelectedCases(new Set(selectedCases));
          updateEndpointCount();
          updateGlobalInterpretation();
          injectControlledStylesheet(sessionId, selectedCases);
          startRuntimeObservation();
        }

        function startRuntimeObservation() {
          const runToken = activeRunToken + 1;
          activeRunToken = runToken;
          pollResults(runToken);
          window.setTimeout(() => {
            if (runToken !== activeRunToken) return;
            if (state.scan === "waiting") {
              state.scan = "not-connected";
              setText("#scan-signal-state", runConfig.diagnosticOrigin === "unsupported" ? "diagnostic signal unavailable on this origin" : "no signal from CSS Sentry");
              updateGlobalInterpretation();
              storeHistory("scan-signal-timeout", { diagnosticOrigin: runConfig.diagnosticOrigin });
            }
            if (state.report === "waiting") {
              state.report = "not-saved";
              setText("#report-signal-state", runConfig.diagnosticOrigin === "unsupported" ? "manual report confirmation required" : "no report acknowledgement yet");
              updateGlobalInterpretation();
            }
          }, 4500);
        }

        function resultPathForSession(sessionId, cases) {
          return `/api/result/${sessionId}.json?cases=${encodeURIComponent(serializeCaseList(cases))}`;
        }

        async function injectControlledStylesheet(sessionId, selectedCases) {
          const styleId = "dynamic-test-style";
          const href = `/api/controlled-css/${encodeURIComponent(sessionId)}.css?cases=${encodeURIComponent(serializeCaseList(selectedCases))}`;
          const response = await fetch(href, { headers: { accept: "text/css" } });
          const css = response.ok ? await response.text() : "";
          let style = document.getElementById(styleId);
          if (!style) {
            style = document.createElement("style");
            style.id = styleId;
            style.textContent = css;
            document.head.appendChild(style);
            return;
          }
          style.textContent = css;
        }

        async function pollResults(runToken) {
          for (let attempt = 0; attempt < 14; attempt += 1) {
            await new Promise((resolve) => window.setTimeout(resolve, attempt === 0 ? 500 : 850));
            if (runToken !== activeRunToken) return;
            const response = await fetch(runConfig.resultPath, { headers: { accept: "application/json" } });
            const body = await response.json().catch(() => null);
            if (!response.ok || body?.ok !== true || !Array.isArray(body.results)) continue;
            for (const result of body.results) {
              const value = result.received === true ? "received" : state.endpointByCase[result.caseId] ?? "pending";
              state.endpointByCase[result.caseId] = value;
              const target = document.querySelector(`[data-endpoint-state="${cssEscape(result.caseId)}"]`);
              if (target) target.textContent = value;
            }
            updateEndpointCount();
            if (Object.values(state.endpointByCase).some((value) => value === "received")) storeHistory("endpoint-received", { endpoints: state.endpointByCase });
          }
          if (runToken !== activeRunToken) return;
          for (const caseId of Object.keys(state.endpointByCase)) {
            if (state.endpointByCase[caseId] === "pending") {
              state.endpointByCase[caseId] = "not-received";
              const target = document.querySelector(`[data-endpoint-state="${cssEscape(caseId)}"]`);
              if (target) target.textContent = "not received";
            }
          }
          updateEndpointCount();
          updateGlobalInterpretation();
          storeHistory("endpoint-poll-complete", { endpoints: state.endpointByCase });
        }

        function updateEndpointCount() {
          const received = Object.values(state.endpointByCase).filter((value) => value === "received").length;
          const total = Object.keys(state.endpointByCase).length;
          setText("#endpoint-hit-count", total > 0 ? `${received} of ${total}` : "not started");
        }

        function updateGlobalInterpretation() {
          const endpointValues = Object.values(state.endpointByCase);
          const manualValues = Object.values(state.manualByCase);
          const endpoint = endpointValues.includes("received") ? "received" : endpointValues.includes("pending") ? "pending" : endpointValues.length > 0 ? "not-received" : "not-run";
          const manual = manualValues.some((value) => value === "reported" || value === "blocked" || value === "sanitized") ? "reported" : manualValues.includes("no-finding") ? "no-finding" : "not-checked";
          const message = deriveInterpretation({ hasSession: Boolean(runConfig.sessionId), endpoint, scan: state.scan, report: state.report, manual, mode: state.mode, diagnosticOrigin: runConfig.diagnosticOrigin });
          const target = document.querySelector("#global-interpretation");
          if (!target) return;
          target.className = `interpretation-card ${message.kind}`;
          target.innerHTML = `<strong>${escapeHtml(message.title)}</strong><p>${escapeHtml(message.detail)}</p>`;
        }

        function deriveInterpretation(input) {
          if (!input.hasSession) return { kind: "review", title: "Start selected checks", detail: "The page adds controlled CSS after a test session is created and records the selected cases in the URL." };
          if (input.scan === "not-connected" && input.diagnosticOrigin === "unsupported") return { kind: "review", title: "Manual report confirmation required", detail: "The extension diagnostic bridge is restricted to supported Test Lab origins. Use the CSS Sentry popup or report page to confirm findings on this origin." };
          if (input.scan === "not-connected") return { kind: "unexpected", title: "CSS Sentry did not signal on this page", detail: "Check extension site access for this origin and whether the installed build includes Test Lab diagnostics." };
          if (input.scan === "scan-disabled") return { kind: "inconclusive", title: "CSS Sentry is present, but scanning is disabled for this origin", detail: "The extension reported its mode without scanning. Re-run in Passive, Balanced, or Strict mode before judging detector behavior." };
          if (input.scan === "connected-no-findings" && input.endpoint === "received") return { kind: "unexpected", title: "Extension scanned but found no matching issue", detail: "The endpoint was reached while CSS Sentry reported zero actionable findings. Treat this as a test-definition or detector-coverage issue." };
          if (input.scan === "findings" && input.report === "not-saved") return { kind: "unexpected", title: "Scanner found issues but the report was not saved", detail: "This separates scanner coverage from the report pipeline." };
          if (input.mode === "not-sure") return { kind: "review", title: "Mode still needs confirmation", detail: "Use the detected CSS Sentry mode when available, or open the manual override only when the diagnostic signal is unavailable." };
          if (["paused", "trusted", "never_scan_never_sanitize"].includes(input.mode)) return { kind: "inconclusive", title: "Mode intentionally allows reduced protection", detail: "Re-run in Passive, Balanced, or Strict before judging detector behavior." };
          if (input.manual === "not-checked") return { kind: "review", title: "Manual CSS Sentry report check needed", detail: "Confirm the popup or full report and record what CSS Sentry showed." };
          if (input.manual === "no-finding" && input.endpoint === "received" && ["balanced", "strict", "default"].includes(input.mode)) return { kind: "unexpected", title: "Endpoint reached with no CSS Sentry finding", detail: "After site access and policy are confirmed, this points to a detector or Test Lab coverage issue." };
          if (input.manual === "reported" && input.mode === "passive" && input.endpoint === "received") return { kind: "expected", title: "Expected Passive-mode report-only result", detail: "CSS Sentry reported the case while allowing the controlled endpoint request to complete." };
          if (input.manual === "reported") return { kind: "expected", title: "CSS Sentry reported the selected checks", detail: "Compare the action shown by CSS Sentry with endpoint state to distinguish report-only behavior from mitigation." };
          return { kind: "review", title: "Review endpoint, scan, report, and mode together", detail: "Use the troubleshooting guide and expected finding terms for the selected checks." };
        }

        function observeStoredDiagnostics() {
          const observer = new MutationObserver((records) => {
            for (const record of records) {
              if (record.attributeName === scanDiagnosticAttribute) {
                applyScanDiagnosticFromRaw(document.documentElement.getAttribute(scanDiagnosticAttribute));
              }
              if (record.attributeName === reportDiagnosticAttribute) {
                applyReportDiagnosticFromRaw(document.documentElement.getAttribute(reportDiagnosticAttribute));
              }
            }
          });
          observer.observe(document.documentElement, { attributes: true, attributeFilter: [scanDiagnosticAttribute, reportDiagnosticAttribute] });
        }

        function applyStoredDiagnostics() {
          applyScanDiagnosticFromRaw(document.documentElement.getAttribute(scanDiagnosticAttribute));
          applyReportDiagnosticFromRaw(document.documentElement.getAttribute(reportDiagnosticAttribute));
        }

        function applyScanDiagnosticFromRaw(rawDetail) {
          const diagnosticKey = diagnosticDeduplicationKey(rawDetail);
          if (!diagnosticKey || diagnosticKey === state.lastScanDiagnosticRaw) return;
          state.lastScanDiagnosticRaw = diagnosticKey;
          applyScanDiagnostic(parseDiagnosticDetail(rawDetail));
        }

        function applyReportDiagnosticFromRaw(rawDetail) {
          const diagnosticKey = diagnosticDeduplicationKey(rawDetail);
          if (!diagnosticKey || diagnosticKey === state.lastReportDiagnosticRaw) return;
          state.lastReportDiagnosticRaw = diagnosticKey;
          applyReportDiagnostic(parseDiagnosticDetail(rawDetail));
        }

        function diagnosticDeduplicationKey(rawDetail) {
          if (typeof rawDetail === "string") return rawDetail;
          if (rawDetail && typeof rawDetail === "object") return JSON.stringify(rawDetail);
          return "";
        }

        function applyScanDiagnostic(detail) {
          if (!detail || detail.connected !== true) return;
          state.mode = typeof detail.mode === "string" ? detail.mode : state.mode;
          if (detail.scanSkipped === true) {
            state.scan = "scan-disabled";
            setText("#scan-signal-state", `connected, scanning disabled by ${state.mode} mode`);
          } else {
            state.scan = detail.actionableFindingCount > 0 ? "findings" : "connected-no-findings";
            setText("#scan-signal-state", detail.actionableFindingCount > 0 ? `connected, ${detail.actionableFindingCount} actionable finding(s)` : "connected, no actionable findings");
          }
          setText("#detected-mode", state.mode);
          updateGlobalInterpretation();
          storeHistory("scan-signal", { mode: state.mode, state: detail.state, reasons: detail.reasons, actions: detail.actions, findingCount: detail.findingCount, actionableFindingCount: detail.actionableFindingCount, scanSkipped: detail.scanSkipped === true });
        }

        function applyReportDiagnostic(detail) {
          if (!detail || detail.connected !== true) return;
          state.report = detail.reportSaved === true ? "saved" : "not-saved";
          setText("#report-signal-state", detail.reportSaved === true ? `saved, ${detail.actionableFindingCount ?? 0} actionable finding(s)` : "report save failed or unavailable");
          updateGlobalInterpretation();
          storeHistory("report-signal", { reportSaved: detail.reportSaved, actionableFindingCount: detail.actionableFindingCount });
        }

        function parseDiagnosticDetail(rawDetail) {
          if (typeof rawDetail === "string") {
            try { return JSON.parse(rawDetail); } catch { return null; }
          }
          return rawDetail && typeof rawDetail === "object" ? rawDetail : null;
        }

        function manualLabel(value) {
          return ({ "not-checked": "not checked", reported: "reported", blocked: "reported and blocked", sanitized: "reported and sanitized", "no-finding": "no finding", unsure: "not sure" })[value] ?? value;
        }

        function setText(selector, value) {
          const element = document.querySelector(selector);
          if (element) element.textContent = value;
        }

        function cssEscape(value) {
          return window.CSS?.escape ? window.CSS.escape(value) : String(value).replace(/[^a-zA-Z0-9_-]/g, "\\$&");
        }

        function escapeHtml(value) {
          return String(value).replace(/[&<>"]/g, (char) => ({ "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;" })[char]);
        }

        function storeHistory(event, detail) {
          if (!runConfig.sessionId) return;
          const item = { at: new Date().toISOString(), cases: runConfig.cases, sessionId: runConfig.sessionId, mode: state.mode, endpoints: state.endpointByCase, scan: state.scan, report: state.report, manual: state.manualByCase, event, detail };
          const current = JSON.parse(localStorage.getItem(historyKey) ?? "[]");
          current.unshift(item);
          localStorage.setItem(historyKey, JSON.stringify(current.slice(0, 50)));
        }
      </script>
    </main>
  </body>
</html>
